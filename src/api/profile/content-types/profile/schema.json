{
  "kind": "singleType",
  "collectionName": "profile",
  "info": {
    "singularName": "profile",
    "pluralName": "profiles",
    "displayName": "Profile",
    "description": "User profile data"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "info": {
      "type": "text"
    },
    "avatar": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "links": {
      "type": "component",
      "repeatable": true,
      "component": "shared.social-link"
    },
    "like_count": {
      "type": "integer",
      "default": 0
    },
    "mood": {
      "type": "string",
      "maxLength": 50
    }
  }
}
